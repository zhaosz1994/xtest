# 依赖目录
node_modules/

# 环境变量文件（包含敏感信息，不应提交）
.env
.env.local
.env.production
.env.development

# 日志文件
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 上传文件目录（运行时生成）
uploads/
public/uploads/

# IDE 配置
.idea/
.vscode/
*.swp
*.swo
*~

# 操作系统文件
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# 构建输出
dist/
build/
out/

# 临时文件
*.tmp
*.temp
.cache/
.parcel-cache/

# 测试覆盖率报告
coverage/
.nyc_output/

# PM2 配置（可能包含敏感信息）
ecosystem.config.js

# 数据库备份文件
*.sql.gz
*.sql.zip
backup/

# 临时测试文件
test_*.js
!tests/
*.test.js

# 报告文件（运行时生成）
uploads/reports/*.md
uploads/reports/*.pdf

# Excel 临时文件
~$*.xlsx
~$*.xls

# 压缩文件
*.zip
*.tar.gz
*.rar
