# 数据库连接信息
# 请复制此文件为 .env 并填写实际值
DB_HOST=localhost
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_NAME=xtest_db
#DB_SOCKET=/data03/users/sdk/www/xtest/mysql/tmp/mysql.sock

# JWT密钥（请使用强随机字符串）
# 生成方法: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_here

# 服务器配置
PORT=3000
NODE_ENV=development

# CORS 允许的域名（多个域名用逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://10.10.25.154:8000

# 可选：邮件服务配置
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your_email@example.com
# SMTP_PASSWORD=your_email_password

# 日志配置
# 日志级别: debug, info, warn, error
LOG_LEVEL=info
# 日志目录（相对于项目根目录）
LOG_DIR=./logs
# 单个日志文件最大大小（MB）
LOG_MAX_FILE_SIZE=10
# 保留的归档日志文件数量
LOG_MAX_FILES=5
# 是否同时输出到控制台
LOG_CONSOLE=true
